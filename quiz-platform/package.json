{
  "name": "quiz-platform",
  "version": "1.0.0",
  "description": "Online Quiz Platform — Full Stack",
  "scripts": {
    "install-all": "cd server && npm install && cd ../client && npm install",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
